        <li><a href="/guides/13-14-gehalt/" class="text-secondary underline hover:text-primary transition-colors">13. und 14. Gehalt erklärt</a> - Sonderzahlungen verstehen</li>
      </ul>
    </div>

    <!-- Quellen -->
    <div class="mt-8 border-t border-gray-200 pt-6">
      <h2 class="text-lg font-bold text-gray-900 mb-3">Quellen</h2>
      <ul class="space-y-1 text-sm text-gray-600">
