  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://nettolohn.at/" },
    { "@type": "ListItem", "position": 2, "name": "Ratgeber", "item": "https://nettolohn.at/guides/" },
    { "@type": "ListItem", "position": 3, "name": "Lohnsteuer in Österreich", "item": "https://nettolohn.at/guides/lohnsteuer-oesterreich/" }
  ]
