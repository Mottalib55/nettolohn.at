---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Seite nicht gefunden | nettolohn.at" description="Die angeforderte Seite wurde nicht gefunden. Kehren Sie zum Brutto-Netto-Rechner zurueck.">
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-7xl font-extrabold text-primary mb-4">404</h1>
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Seite nicht gefunden</h2>
      <p class="text-gray-600 mb-8 max-w-md mx-auto">
        Die von Ihnen gesuchte Seite existiert nicht oder wurde verschoben.
        Bitte ueberpruefen Sie die URL oder kehren Sie zur Startseite zurueck.
      </p>
      <a
        href="/"
        class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-white font-semibold hover:bg-primary-dark transition-colors shadow-md"
      >
        Zurueck zur Startseite
      </a>
    </div>
  </section>
</Layout>
