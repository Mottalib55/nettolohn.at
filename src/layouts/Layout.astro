---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = 'Kostenloser Brutto-Netto-Rechner für Österreich 2026. Berechnen Sie Ihr Nettogehalt mit Sozialversicherung, Lohnsteuer, Sonderzahlungen und Familienbonus Plus.', canonical } = Astro.props;
const canonicalURL = canonical ? new URL(canonical, Astro.site) : new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mottalib Radif" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="de_AT" />
    <meta property="og:site_name" content="nettolohn.at" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "nettolohn.at — Brutto-Netto-Rechner Österreich",
      "description": description,
      "url": "https://nettolohn.at",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "inLanguage": "de-AT"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nettolohn Rechner Osterreich",
      "url": "https://nettolohn.at",
      "logo": "https://nettolohn.at/favicon.svg",
      "founder": {
        "@type": "Person",
        "name": "Mottalib Radif"
      }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Mottalib Radif",
      "jobTitle": "Experte für Finanzplanung & Steuertechnologie",
      "description": "MBA INSEAD Absolvent, begeistert von österreichischer Finanzplanung. Spezialisiert auf Lohnsteuer, Sozialversicherung und Gehaltsoptimierung.",
      "alumniOf": { "@type": "EducationalOrganization", "name": "INSEAD" },
      "image": "https://nettolohn.at/team/mottalib-radif.jpg",
      "url": "https://nettolohn.at/ueber-uns/"
    })} />

    <script defer data-domain="nettolohn.at" src="https://plausible.io/js/script.js"></script>

    <!-- Google Analytics 4 — replace G-XXXXXXXXXX with real ID -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-blue-700 focus:rounded-lg focus:shadow-lg focus:ring-2 focus:ring-blue-500">Skip to content</a>
    <!-- Header -->
    <header class="bg-primary text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
            <span class="text-2xl font-extrabold tracking-tight">nettolohn.at</span>
          </a>
          <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
            <a href="/#rechner" class="hover:text-accent-light transition-colors">Rechner</a>
            <a href="/guides/" class="hover:text-accent-light transition-colors">Ratgeber</a>
            <a href="/faq/" class="hover:text-accent-light transition-colors">FAQ</a>
            <a href="/impressum/" class="hover:text-accent-light transition-colors">Impressum</a>
            <a href="/datenschutz/" class="hover:text-accent-light transition-colors">Datenschutz</a>
          </nav>
          <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menü öffnen">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/20">
        <nav class="px-4 py-3 space-y-2">
          <a href="/#rechner" class="block py-2 text-sm font-medium hover:text-accent-light">Rechner</a>
          <a href="/guides/" class="block py-2 text-sm font-medium hover:text-accent-light">Ratgeber</a>
          <a href="/faq/" class="block py-2 text-sm font-medium hover:text-accent-light">FAQ</a>
          <a href="/impressum/" class="block py-2 text-sm font-medium hover:text-accent-light">Impressum</a>
          <a href="/datenschutz/" class="block py-2 text-sm font-medium hover:text-accent-light">Datenschutz</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h4 class="text-white font-bold text-lg mb-3">nettolohn.at</h4>
            <p class="text-sm">Kostenloser Brutto-Netto-Rechner für Österreich. Berechnen Sie Ihr Nettogehalt schnell und einfach.</p>
          </div>
          <div>
            <h4 class="text-white font-bold mb-3">Links</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="hover:text-white transition-colors">Startseite</a></li>
              <li><a href="/guides/" class="hover:text-white transition-colors">Ratgeber</a></li>
              <li><a href="/faq/" class="hover:text-white transition-colors">Häufige Fragen</a></li>
              <li><a href="/impressum/" class="hover:text-white transition-colors">Impressum</a></li>
              <li><a href="/datenschutz/" class="hover:text-white transition-colors">Datenschutz</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-bold mb-3">Hinweis</h4>
            <p class="text-sm">Die Berechnungen dienen nur zur Information und ersetzen keine professionelle Steuerberatung. Alle Angaben ohne Gewähr.</p>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} nettolohn.at — Alle Rechte vorbehalten.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
